# =============================================================
#  FitAI Trainer — Production Environment Variables Example
#  Copy this file to .env (in each sub-folder as noted) and
#  fill in your real values before deploying.
# =============================================================


# ─────────────────────────────────────────────
# BACKEND  (Backend/.env)
# ─────────────────────────────────────────────

# SQLite DB file path (relative to Backend/)
# Default: fitness.db — change only if you want a custom location
DATABASE_URL=sqlite:///./fitness.db

# MongoDB (optional — only needed for legacy MongoDB routes)
# Leave blank to skip; backend falls back to SQLite-only mode
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/fitai?retryWrites=true&w=majority

# SMTP — for OTP email delivery (Gmail example)
# If left blank the OTP is returned in the API response (dev/demo mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password        # 16-char App Password (not your Gmail login)
SMTP_FROM=your_gmail_address@gmail.com   # Display "From" address

# ElevenLabs — AI voice responses in the chatbot
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Ollama — local LLM (Mistral-Nemo)
# Default URL when Ollama is running locally
OLLAMA_BASE_URL=http://localhost:11434

# App secret key (used for session token signing — change to a random string)
SECRET_KEY=change_me_to_a_long_random_string_in_production

# Google token verification (set to false ONLY for local development testing)
# In production this MUST be true (default) to prevent account impersonation
GOOGLE_VERIFY_TOKENS=true

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000


# ─────────────────────────────────────────────
# FRONTEND  (frontend/.env.local)
# ─────────────────────────────────────────────

# Firebase — Google Sign-In for the web app
# Create a project at https://console.firebase.google.com
# Enable "Google" as a Sign-In provider, then copy the web app config here
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# Backend API URL as seen from the browser
# In production point this at your deployed backend domain
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend server port
NEXT_PUBLIC_PORT=5000


# ─────────────────────────────────────────────
# MOBILE APP  (mobile/.env)
# ─────────────────────────────────────────────

# Backend API URL as seen from the mobile device / emulator
# Use your machine's LAN IP (not localhost) when running on a real device
# e.g. http://192.168.1.100:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Firebase — Google Sign-In for the mobile app
# Same Firebase project as above; add the Android/iOS app in the Firebase console
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Google OAuth Web Client ID (from Firebase > Authentication > Sign-in method > Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Expo project slug (from app.json)
EXPO_PUBLIC_SLUG=fitai-trainer


# ─────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────
# 1. NEVER commit real secrets to git — add .env to .gitignore
# 2. Gmail SMTP_PASS must be a Google App Password, not your account password.
#    Enable 2FA on your Google account, then generate an App Password at:
#    https://myaccount.google.com/apppasswords
# 3. Ollama must be installed and running locally for LLM features.
#    Download: https://ollama.com   Model: mistral-nemo
#    The backend falls back to keyword-based responses if Ollama is unavailable.
# 4. Firebase setup guide: https://firebase.google.com/docs/web/setup
# =============================================================
